        /// <summary>
        /// The description of this Composition as defined by the MTConnect Standard.
        /// </summary>
        public override string TypeDescription => DescriptionText;
{{- if (maximum_version_enum) }}

        /// <summary>
        /// The maximum MTConnect Version that this Composition is valid for; set when the type has been deprecated.
        /// </summary>
