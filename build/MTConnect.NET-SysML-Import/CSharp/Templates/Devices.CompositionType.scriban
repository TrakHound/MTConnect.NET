        public override System.Version MinimumVersion => {{ minimum_version_enum }};
{{- end }}


        /// <summary>
        /// Initializes a new instance with its <c>Type</c> set to <see cref="TypeId"/>.
        /// </summary>
        public {{name}}() { Type = TypeId; }
    }
