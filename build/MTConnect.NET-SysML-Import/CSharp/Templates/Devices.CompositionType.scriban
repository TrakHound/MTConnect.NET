namespace MTConnect.Devices.Compositions
{
    /// <summary>
    /// {{description}}
    /// </summary>
    public class {{name}} : {{ if (parent_type) }}{{parent_type}}{{else}}Composition{{ end }} 
    {
        /// <summary>
        /// The MTConnect <c>type</c> value that identifies this Composition.
        /// </summary>
        public const string TypeId = "{{type}}";

        /// <summary>
        /// The default <c>name</c> assigned to an instance of this Composition.
        /// </summary>
        public const string NameId = "{{default_name}}";

        /// <summary>
        /// The description of this Composition as defined by the MTConnect Standard.
        /// </summary>
