<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0</TargetFramework>
		<RootNamespace>MTConnect.NET_SysML_Import</RootNamespace>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Scriban" Version="7.0.0" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\..\libraries\MTConnect.NET-SysML\MTConnect.NET-SysML.csproj" />
	</ItemGroup>

	<!--
	  Copy every Scriban template under each renderer's `Templates/` subtree
	  to the build output. Using forward-slash wildcard globs so the build is
	  reliable on Linux/macOS as well as Windows (MSBuild on POSIX does not
	  reliably interpret backslash separators in glob patterns; forward
	  slashes work on all platforms).

	  Adding a new template = drop it under the matching renderer's
	  `Templates/` directory. No csproj edit required. The fail-fast
	  `EnsureTemplateTreesExist` startup check in `Program.cs` is the safety
	  net for an empty or absent directory.
	-->
	<ItemGroup>
		<None Update="CSharp/Templates/**/*.scriban" CopyToOutputDirectory="Always" />
		<None Update="Json-cppagent/Templates/**/*.scriban" CopyToOutputDirectory="Always" />
		<None Update="Xml/Templates/**/*.scriban" CopyToOutputDirectory="Always" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Protobuf\" />
	</ItemGroup>

</Project>
