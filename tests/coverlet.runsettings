<?xml version="1.0" encoding="utf-8"?>
<!--
  Shared Coverlet configuration for every tests/**/*.csproj.

  Reference from dotnet test with the settings flag pointing at this
  file. The tools harness (tools/test.sh) passes it automatically. CI
  uploads the produced TestResults/**/*.cobertura.xml files as the
  coverage artifact.

  Format: cobertura is the widely-supported lowest-common-denominator.
  ReportGenerator (pinned via .config/dotnet-tools.json) turns every
  cobertura.xml into an HTML + Summary.txt at coverage-report/.

  Exclusion rationale:
    - *.g.cs are generator output and ARE gated. They are not excluded
      here. Generator-output `.g.cs` files are part of the coverage
      gate; tests exercise their constructors, properties, and
      per-subtype description methods.
    - TestHelpers / TestDoubles under tests/** are excluded because
      they are test-only infrastructure. Coverlet runs against the
      library assemblies, not the test assemblies, so the Include
      filter already scopes it out. The ExcludeByFile pattern is kept
      in place so that any future TestHelpers/ / TestDoubles/ tree is
      excluded automatically.
    - obj/ + bin/ are excluded via Coverlet's built-in defaults.

  Assembly-level test parallelism:
    MaxCpuCount=1 forces VSTest to run one test-host process at a
    time. When `dotnet test` is given the solution it otherwise fans
    out one host per test assembly across the logical CPUs, so the
    timing-sensitive in-process HTTP server tests in
    MTConnect.NET-Integration-Tests co-run with the heavy compliance,
    MQTT-relay E2E, and reflection coverage assemblies. On a 2-CPU CI
    runner that co-running load scheduler-starves the integration
    agent's heartbeat and sample-delivery threads, so a sample arrives
    after the test's own assertion wait elapses. Serializing the
    assemblies removes the cross-assembly starvation at the root while
    every assembly's tests still run; xUnit's
    [assembly: CollectionBehavior(DisableTestParallelization = true)]
    only governs parallelism within an assembly, not across the host
    processes VSTest spawns for a solution, so this is the matching
    knob for that layer. Both CI and tools/test.sh pass this file via
    the settings argument, so the single setting covers every entry
    point.
-->
<RunSettings>
    <RunConfiguration>
        <MaxCpuCount>1</MaxCpuCount>
    </RunConfiguration>
    <DataCollectionRunSettings>
        <DataCollectors>
            <DataCollector friendlyName="XPlat code coverage">
                <Configuration>
                    <Format>cobertura</Format>
                    <Include>[MTConnect.NET-*]*</Include>
                    <Exclude>[MTConnect.NET-*-Tests]*,[MTConnect.NET-*-Tests.*]*</Exclude>
                    <ExcludeByFile>**/*.g.cs.bak,**/TestHelpers/**/*.cs,**/TestDoubles/**/*.cs</ExcludeByFile>
                    <ExcludeByAttribute>Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
                    <SingleHit>false</SingleHit>
                    <UseSourceLink>true</UseSourceLink>
                    <IncludeTestAssembly>false</IncludeTestAssembly>
                    <SkipAutoProps>false</SkipAutoProps>
                    <DeterministicReport>true</DeterministicReport>
                </Configuration>
            </DataCollector>
        </DataCollectors>
    </DataCollectionRunSettings>
</RunSettings>
